<resources>

    <style
        name="Theme.Kira"
        parent="Theme.Material3.DynamicColors.DayNight">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>

        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowLightStatusBar">?isLightTheme</item>
        <item name="android:windowLightNavigationBar">?isLightTheme</item>
        
        <item name="toolbarIconColor">@color/theme_dark_on_primary</item>
        <item name="item_background_selected">?colorPrimary</item>
        <item name="item_background_normal">?colorSurface</item>
    </style>



    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/control_blue</item>
        <item name="colorPrimaryDark">@color/control_blue</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorControlHighlight">@color/colorControlHighlight</item>
        <item name="colorControlNormal">@color/colorControlNormal</item>
        <item name="colorOnPrimary">@color/theme_dark_on_primary</item>
        <item name="colorSurface">@color/theme_dark_surface</item>
        <item name="colorOnSurface">@color/theme_dark_on_surface</item>
        <item name="android:windowBackground">@color/theme_dark_surface</item>
        <item name="android:navigationBarColor">@color/theme_dark_surface</item>
        <item name="android:statusBarColor">@color/theme_dark_surface</item>
        <item name="popupTheme">@style/AppTheme.PopupOverlay.Dark</item>
        <item name="toolbarIconColor">@color/theme_dark_on_primary</item>
    </style>
    <style name="AppTheme_Dark" parent="AppTheme" />
    <style name="AppTheme_Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/control_blue</item>
        <item name="colorPrimaryDark">@color/control_blue</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorControlHighlight">@color/colorControlHighlight</item>
        <item name="colorControlNormal">@color/colorControlNormal</item>
        <item name="colorOnPrimary">@color/theme_light_on_primary</item>
        <item name="colorSurface">@color/theme_light_surface</item>
        <item name="colorOnSurface">@color/theme_light_on_surface</item>
        <item name="android:windowBackground">@color/theme_light_surface</item>
        <item name="android:navigationBarColor">@color/theme_light_surface</item>
        <item name="android:statusBarColor">@color/theme_light_surface</item>
        <item name="popupTheme">@style/AppTheme.PopupOverlay.Light</item>
        <item name="toolbarIconColor">@color/theme_light_on_primary</item>
    </style>
    <style name="AppTheme_Black" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/control_blue</item>
        <item name="colorPrimaryDark">@color/control_blue</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorControlHighlight">@color/colorControlHighlight</item>
        <item name="colorControlNormal">@color/colorControlNormal</item>
        <item name="colorOnPrimary">@color/theme_black_on_primary</item>
        <item name="colorSurface">@color/theme_black_surface</item>
        <item name="colorOnSurface">@color/theme_black_on_surface</item>
        <item name="android:windowBackground">@color/theme_black_surface</item>
        <item name="android:navigationBarColor">@color/theme_black_surface</item>
        <item name="android:statusBarColor">@color/theme_black_surface</item>
        <item name="popupTheme">@style/AppTheme.PopupOverlay.Dark</item>
        <item name="toolbarIconColor">@color/theme_black_on_primary</item>
    </style>
    <style name="AppTheme_Dynamic_Dark" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorSurface">@color/theme_dark_surface</item>
        <item name="colorOnSurface">@color/theme_dark_on_surface</item>
        <item name="android:windowBackground">@color/theme_dark_surface</item>
        <item name="android:navigationBarColor">@color/theme_dark_surface</item>
        <item name="android:statusBarColor">@color/theme_dark_surface</item>
        <item name="popupTheme">@style/AppTheme.PopupOverlay.Dark</item>
        <item name="toolbarIconColor">@color/theme_dark_on_primary</item>
    </style>
    <style name="AppTheme_Dynamic_Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorSurface">@color/theme_light_surface</item>
        <item name="colorOnSurface">@color/theme_light_on_surface</item>
        <item name="android:windowBackground">@color/theme_light_surface</item>
        <item name="android:navigationBarColor">@color/theme_light_surface</item>
        <item name="android:statusBarColor">@color/theme_light_surface</item>
        <item name="popupTheme">@style/AppTheme.PopupOverlay.Light</item>
        <item name="toolbarIconColor">@color/theme_light_on_primary</item>
    </style>
    <style name="AppTheme_Dynamic_Black" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorSurface">@color/theme_black_surface</item>
        <item name="colorOnSurface">@color/theme_black_on_surface</item>
        <item name="android:windowBackground">@color/theme_black_surface</item>
        <item name="android:navigationBarColor">@color/theme_black_surface</item>
        <item name="android:statusBarColor">@color/theme_black_surface</item>
        <item name="popupTheme">@style/AppTheme.PopupOverlay.Dark</item>
        <item name="toolbarIconColor">@color/theme_black_on_primary</item>
    </style>
    <style name="AppTheme_Dynamic_Black_Override">
        <item name="colorSurface">@color/theme_black_surface</item>
        <item name="colorOnSurface">@color/theme_black_on_surface</item>
        <item name="android:windowBackground">@color/theme_black_surface</item>
        <item name="android:navigationBarColor">@color/theme_black_surface</item>
        <item name="android:statusBarColor">@color/theme_black_surface</item>
    </style>
    <style name="AppTheme.FullScreen" parent="AppTheme">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.Material3.ActionBar" />
    <style name="AppTheme.PopupOverlay.Dark" parent="ThemeOverlay.Material3.Dark">
        <item name="colorControlNormal">@color/theme_dark_on_surface</item>
        <item name="colorControlActivated">@color/colorAccent</item>
        <item name="colorOnSurface">@color/theme_dark_on_surface</item>
    </style>
    <style name="AppTheme.PopupOverlay.Light" parent="ThemeOverlay.Material3.Light">
        <item name="colorControlNormal">@color/theme_light_on_surface</item>
        <item name="colorControlActivated">@color/colorAccent</item>
        <item name="colorOnSurface">@color/theme_light_on_surface</item>
    </style>
</resources>
