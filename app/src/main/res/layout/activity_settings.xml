<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings_coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/settings_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/settings_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:popupTheme="?attr/popupTheme" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Show System Apps -->
                <LinearLayout
                    android:id="@+id/settings_show_system"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurface"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                        android:id="@+id/title_show_system"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show system apps"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp" />

                        <TextView
                            android:id="@+id/summary_show_system"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Display system applications in the list"
                            android:textColor="?attr/colorOnSurface"
                            android:alpha="0.7"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_show_system"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/switch_thumb_tint"
                        app:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View
                    android:id="@+id/divider_dynamic_colors"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOnSurface"
                    android:alpha="0.12" />

                <!-- Show Persistent Apps -->
                <LinearLayout
                    android:id="@+id/settings_show_persistent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurface"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                        android:id="@+id/title_show_persistent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show persistent apps"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp" />

                        <TextView
                            android:id="@+id/summary_show_persistent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Display persistent applications in the list"
                            android:textColor="?attr/colorOnSurface"
                            android:alpha="0.7"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_show_persistent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/switch_thumb_tint"
                        app:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOnSurface"
                    android:alpha="0.12" />

                <!-- Auto Refresh -->
                <LinearLayout
                    android:id="@+id/settings_auto_refresh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurface"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                        android:id="@+id/title_auto_refresh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto refresh"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp" />

                        <TextView
                            android:id="@+id/summary_auto_refresh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Automatically refresh the app list"
                            android:textColor="?attr/colorOnSurface"
                            android:alpha="0.7"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_auto_refresh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/switch_thumb_tint"
                        app:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOnSurface"
                    android:alpha="0.12" />

                <!-- Full Screen -->
                <LinearLayout
                    android:id="@+id/settings_full_screen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurface"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                        android:id="@+id/title_full_screen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full screen"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp" />

                        <TextView
                            android:id="@+id/summary_full_screen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hide the status bar and use the full screen"
                            android:textColor="?attr/colorOnSurface"
                            android:alpha="0.7"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_full_screen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/switch_thumb_tint"
                        app:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOnSurface"
                    android:alpha="0.12" />

                <!-- Dynamic Colors -->
                <LinearLayout
                    android:id="@+id/settings_dynamic_colors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurface"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                        android:id="@+id/title_dynamic_colors"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dynamic_colors"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp" />

                        <TextView
                            android:id="@+id/summary_dynamic_colors"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dynamic_colors_summary"
                            android:textColor="?attr/colorOnSurface"
                            android:alpha="0.7"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_dynamic_colors"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/switch_thumb_tint"
                        app:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOnSurface"
                    android:alpha="0.12" />

                <!-- Theme -->
                <LinearLayout
                    android:id="@+id/settings_theme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurface"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/title_theme"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/theme"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/summary_theme"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/theme_summary"
                            android:textColor="?attr/colorOnSurface"
                            android:alpha="0.7"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/theme_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOnSurface"
                    android:alpha="0.12" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
